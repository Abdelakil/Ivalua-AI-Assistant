# =============================================================================
# Portable toolchain (auto-created by conport_launcher on first run)
# =============================================================================
.tools/
.venv/

# =============================================================================
# Python
# =============================================================================
__pycache__/
*.pyc
*.pyo
*.pyd
*.egg-info/

# =============================================================================
# ConPort runtime artefacts (regenerated at runtime)
# =============================================================================
context_portal/logs/
context_portal/alembic/__pycache__/

# SQLite write-ahead-log / shared-memory files (db itself IS tracked)
context_portal/context.db-wal
context_portal/context.db-shm
context_portal/context.db-journal

# Generated import chunks (rebuilt by CI and by local import)
context_portal/import_data/*.json
!context_portal/import_data/.gitkeep

# Vector index auto-rebuilds from context.db on first semantic search
context_portal/conport_vector_data/

# =============================================================================
# OS / editor junk
# =============================================================================
.DS_Store
Thumbs.db
*.swp
*.swo
.idea/
*.iml
.vscode/*
!.vscode/mcp.json
!.vscode/settings.json
!.vscode/extensions.json
